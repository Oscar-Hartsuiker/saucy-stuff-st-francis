---
import { type CollectionEntry, getCollection } from 'astro:content';
import BlogPost from '../../layouts/Layout.astro';
import Layout from '../../layouts/Layout.astro';
import { render } from 'astro:content';


type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await render(post);

const base = import.meta.env.BASE_URL;

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}


// Structured Data for SEO
const structuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,

};
---

<Layout
  title={post.data.title}
  description={post.data.description}
  type="article"
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
<article class="max-w-3xl mx-auto" aria-labelledby="article-title">
    
    <div class="max-w-3xl mx-auto">
      <header class="mb-8">
        <h1 id="article-title" class="text-center text-4xl font-bold mb-4 text-gray-900 dark:text-gray-100">{post.data.title}</h1>

  

             </header>

      <div class="prose dark:prose-invert" role="main" id="main-content">
        <Content />
      </div>

      <hr class="my-10 border-gray-300 dark:border-gray-700"  />

      <nav class="text-center" aria-label="Post navigation">
        <a
          href={`${base}blog`}
          class="inline-block px-6 py-3 border-2 border-blue-600 dark:border-blue-400 text-blue-600 dark:text-blue-400 rounded-md hover:bg-blue-600 hover:text-white dark:hover:bg-blue-400 dark:hover:text-gray-900 transition-colors duration-200"
          aria-label="Return to blog post listing"
        >
          ← Back
        </a>
      </nav>
    </div>
  </article>
</Layout>

<style is:global>
  .prose {
    text-align: center;
    max-width: 100%;
    line-height: 1.8;
    color: #374151;
  }

  .dark .prose {
    text-align: center;
    color: #d1d5db;
  }

  .prose h1,
  .prose h2,
  .prose h3,
  .prose h4,
  .prose h5,
  .prose h6 {
    margin-top: 2rem;
    margin-bottom: 1rem;
    font-weight: 600;
    color: #1f2937;
  }

  .dark .prose h1,
  .dark .prose h2,
  .dark .prose h3,
  .dark .prose h4,
  .dark .prose h5,
  .dark .prose h6 {
    color: #f3f4f6;
  }

  .prose h1 {
    font-size: 2rem;
  }

  .prose h2 {
    font-size: 1.5rem;
  }

  .prose h3 {
    font-size: 1.25rem;
  }

  .prose p {
    margin-bottom: 1.5rem;
  }

  .prose a {
    color: #007bff;
    text-decoration: none;
  }

  .dark .prose a {
    color: #60a5fa;
  }

  .prose a:hover {
    text-decoration: underline;
  }

  .prose pre {
    background-color: #2d2d2d;
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .dark .prose pre {
    background-color: #1f2937;
  }

  .prose code {
    background-color: #f4f4f4;
    color: #1f2937;
    padding: 0.2rem 0.4rem;
    border-radius: 0.25rem;
    font-size: 0.9em;
  }

  .dark .prose code {
    background-color: #374151;
    color: #e5e7eb;
  }

  .prose pre code {
    background-color: transparent;
    padding: 0;
    color: #f8f8f2;
  }

  .prose ul,
  .prose ol {
    margin-bottom: 1.5rem;
    padding-left: 2rem;
  }

  .prose li {
    margin-bottom: 0.5rem;
  }

  .prose blockquote {
    border-left: 4px solid #ddd;
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: #666;
    font-style: italic;
  }

  .dark .prose blockquote {
    border-left-color: #4b5563;
    color: #9ca3af;
  }

  .prose img {
    max-width: 100%;
    height: auto;
    margin: 1.5rem 0;
  }
  .table {
    align-self: center;
  }
  .prose table {
    @apply mx-auto;
    width: 90%;
    border-collapse: collapse;
  }

  .prose th,
  .prose td {
    border: 1px solid #ddd;
    padding: 0.75rem;
    text-align: center;
  }

  .dark .prose th,
  .dark .prose td {
    border-color: #4b5563;
  }

  .prose th {
    background-color: #f4f4f4;
    font-weight: 600;
  }

  .dark .prose th {
    background-color: #374151;
  }

  /* Print styles for better PDF export and printing */
  @media print {
    body {
      background: white !important;
      color: black !important;
    }

    article {
      max-width: 100% !important;
      padding: 0 !important;
    }

    .prose {
      color: black !important;
    }

    .prose h1,
    .prose h2,
    .prose h3,
    .prose h4,
    .prose h5,
    .prose h6 {
      color: black !important;
      page-break-after: avoid;
    }

    .prose a {
      color: #0066cc !important;
      text-decoration: underline;
    }

    .prose a[href]:after {
      content: " (" attr(href) ")";
      font-size: 0.8em;
      font-weight: normal;
    }

    .prose pre,
    .prose code {
      background-color: #f5f5f5 !important;
      color: black !important;
      border: 1px solid #ddd;
    }

    .prose img {
      max-width: 100% !important;
      page-break-inside: avoid;
    }

    .prose table {
      page-break-inside: avoid;
    }

    /* Hide navigation elements when printing */
    nav[aria-label="Post navigation"],
    header > nav,
    footer {
      display: none !important;
    }

    hr {
      border-color: #999 !important;
    }
  }
</style>
