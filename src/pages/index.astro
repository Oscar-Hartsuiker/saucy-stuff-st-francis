---
import Layout from '../layouts/Layout.astro';
import { SITE_CONFIG } from '../config';

const base = import.meta.env.BASE_URL;
---

<Layout title={`${SITE_CONFIG.title} - Home`} showCopyright={false} compactFooter={true}>
<div class="flex items-center item-stretch flex-col md:flex-row min-h-screen">


  <div class="w-1/2 inset-0 content-center ">
    <main role="main" class="text-center px-4 sm:px-6 lg:px-8">
      <div class="mb-8">
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold text-gray-900 dark:text-gray-100 mb-4">
        {SITE_CONFIG.title}
        </h1>
        <p class="text-l sm:text-4xl text-gray-600 dark:text-gray-400 ">
          {SITE_CONFIG.description}
        </p>
      </div>
      <div class="flex justify-center gap-4 flex-wrap">
        <a
          href={`${base}blog`}
          class="px-6 py-3 bg-yellow-300 hover:bg-pink-400 dark:bg-yellow-300 dark:hover:bg-pink-400 text-gray-900 font-medium rounded-lg transition-colors duration-200"
        >
          Read the Menu
        </a>
        <a
          href={`${base}about`}
          class="px-6 py-3 bg-yellow-300 hover:bg-pink-400 dark:bg-yellow-300 dark:hover:bg-pink-400 text-gray-900  font-medium rounded-lg transition-colors duration-200"
        >
          About Me
        </a>
      </div>
    </main>
    </div>
   <div class="w-full md:w-1/2 h-64 md:h-94 bg-cover bg-center"
    style={`background-image: url('${base}media/salad.jpg')`}>
  </div>
</div>
</Layout>
