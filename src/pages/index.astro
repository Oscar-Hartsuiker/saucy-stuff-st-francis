---
import Layout from "../layouts/Layout.astro";
import { SITE_CONFIG } from "../config";
import { getCollection, render } from "astro:content";
import Contact from "../components/whatsapp.astro";
import About from "../components/about.astro";
import Testimonials from "../components/testimonials.astro";
import { Icon } from "astro-icon/components";
const base = import.meta.env.BASE_URL;
const posts = await getCollection("blog"); // ← your collection name
const sortedPosts = posts.sort(
  (a, b) => b.data.updatedDate.valueOf() - a.data.updatedDate.valueOf(),
);
const latestPost = sortedPosts[0];
const { Content } = await render(latestPost); // ← renders the markdown body
---

<Layout
  title={`${SITE_CONFIG.title} - Home`}
  showCopyright={false}
  compactFooter={true}
>
  <main>
    <div
      id="home"
      class="min-w-full flex justify-center shadow min-h-lvh sm:mb-16 bg-cover bg-center"
      style={`background-image: url('${base}media/salad.jpg')`}
    >
      <div class="min-h-dvh content-center">
        <div
          class="p-8 rounded-2xl bg-gray-300/90 backdrop-blur-3xl m-4 shadow-2xl"
        >
          <div class="text-center text-2xl">
            <h2
              class="text-[10vw] font-['Oblata_Display'] whitespace-nowrap text-center w-full text-gray-900 dark:text-gray-900"
            >
              {SITE_CONFIG.title}
            </h2>
            <p class="text-l sm:text-2xl m-2 text-gray-500 dark:text-gray-900">
              {SITE_CONFIG.description}
            </p>
          </div>
        </div>
      </div>
    </div>

    <!--- <div class="m-4"><Testimonials /></div> -->
    <div
      class="grid md:grid-cols-2 h-fit flex-col md:flex-2 flex-wrap gap-4 justify-between m-4"
    >
      <div
        class="p-4 md:p-8 bg-gray-100 dark:bg-gray-800/50 flex drop-shadow-2xl text-xl rounded-2xl"
      >
        <div class="flex">
          <Icon
            name="mdi:silverware-fork-knife"
            class="h-full w-20 content-center pr-4 text-gray-300"
          />
        </div><div class="flex-3">
          <h3 class="text-2xl">
            Enjoy wholesome, home-cooked meals delivered right to your door.
          </h3>
        </div>
      </div>
      <div
        class="p-4 md:p-8 bg-gray-100 dark:bg-gray-800/50 flex drop-shadow-2xl text-xl rounded-2xl"
      >
        <div class="flex">
          <Icon
            name="mdi:lighthouse"
            class="h-full w-20 content-center pr-4 text-gray-300"
          />
        </div><div class="flex-3">
          <h3 class="text-2xl">
            Delivery available to Cape st francis and st Francis Bay.
          </h3>
        </div>
      </div>
      <div
        id="menu"
        class="p-4 md:p-8 row-span-6 bg-black/50 drop-shadow-2xl rounded-2xl"
      >
        <p class="text-center mb-4 text-yellow-200">
          Last Updated
          <time
            datetime={latestPost.data.updatedDate.toISOString()}
            class="text-gray-200 justify-center dark:text-gray-300 mb-4"
          >
            {
              latestPost.data.updatedDate.toLocaleDateString("en-ZA", {
                year: "numeric",
                month: "long",
                weekday: "long",
                day: "numeric",
              })
            }
          </time>
        </p>
        <h2 class="text-2xl text-center text-white font-bold mb-2">
          {latestPost.data.title}
        </h2>

        <p class="text-gray-200 text-xl text-center dark:text-gray-300 mb-4">
          {latestPost.data.description}
        </p>

        <div class="prose text-2xl dark:prose-invert">
          <Content />
        </div>
      </div>
      <div
        class="mb-2 p-4 md:p-8 bg-gray-100 dark:bg-gray-800/50 flex drop-shadow-2xl text-xl rounded-2xl"
      >
        <div class="flex">
          <Icon
            name="mdi:calendar"
            class="h-full w-20 content-center pr-4 text-gray-300"
          />
        </div><div class="flex-3">
          <h2 class="mb-2 text-3xl">
            Saucy Stuff menu is released every Sunday
          </h2><p>
            View it here on my website or join <a
              class="dark:text-green-400 text-green-800 underline"
              href="https://chat.whatsapp.com/JNp96Y7p6k07aPSMR8j4Gs?s=sh&p=a&ilr=2"
              target="_blank">Saucy Stuff WhatsApp Group</a
            > to get it sent directly to your phone.
          </p>
        </div>
      </div>
      <div
        class="mb-2 p-4 md:p-8 bg-gray-100 dark:bg-gray-800/50 flex drop-shadow-2xl text-xl rounded-2xl"
      >
        <div class="flex">
          <Icon
            name="mdi:cart"
            class="h-full w-20 content-center pr-4 text-gray-300"
          />
        </div><div class="flex-3">
          <h2 class="mb-2 text-3xl">Pre-Ordering</h2>
          <p>
            Please get your orders in by 8:00 AM each day, or pre order in
            advance for orders over 3pc. Everything is made-to-order with fresh,
            limited stock.
          </p>
        </div>
      </div>
      <div
        class="mb-2 p-4 md:p-8 bg-gray-100 dark:bg-gray-800/50 flex drop-shadow-2xl text-xl rounded-2xl"
      >
        <div class="flex">
          <Icon
            name="mdi:mobile-phone"
            class="h-full w-20 content-center pr-4 text-gray-300"
          />
        </div><div class="flex-3">
          <h2 class="mb-2 text-3xl">Ordering</h2>
          <p>
            Call or Message your order and delivery address on WhatsApp at
            0813885967
          </p>
        </div>
      </div>

      <div
        class="mb-2 p-4 md:p-8 bg-gray-100 dark:bg-gray-800/50 flex drop-shadow-2xl text-xl rounded-2xl"
      >
        <div class="flex">
          <Icon
            name="mdi:car"
            class="h-full w-20 content-center pr-4 text-gray-300"
          />
        </div><div class="flex-3">
          <h2 class="text-3xl mb-2">Delivery</h2>
          <p>
            Your meals are freshly prepared each morning and arrive between
            12:00 PM and 2:00 PM, ready to heat and eat whenever you’re hungry!
          </p>
        </div>
      </div>
      <div
        class="text-2xl bg-gray-100 dark:bg-gray-800/50 drop-shadow-2xl rounded-2xl"
      >
        <Contact />
      </div>
      <div class="rounded-2xl drop-shadow-2xl">
        <img
          class="w-full rounded-2xl"
          src="/media/pinup.png"
          alt="Your Image"
        />
      </div>
    </div>
  </main>
  <div id="about" class="text-2xl p-4 m-4 md:p-8 rounded-2xl">
    <About />
  </div>
</Layout>
<!-- Tailwind helper to hide scrollbars globally or inline -->
<style is:global>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .prose {
    text-align: center;
    font-size: 1.5rem;
    max-width: 100%;
    line-height: 1.75;
    color: #374151;
  }

  .dark .prose {
    text-align: center;
    color: #d1d5db;
  }

  .prose h1,
  .prose h2,
  .prose h3,
  .prose h4,
  .prose h5,
  .prose h6 {
    margin-top: 2rem;
    margin-bottom: 1rem;
    font-weight: 600;
    color: #1f2937;
  }

  .dark .prose h1,
  .dark .prose h2,
  .dark .prose h3,
  .dark .prose h4,
  .dark .prose h5,
  .dark .prose h6 {
    color: #f3f4f6;
  }

  .prose h1 {
    font-size: 2rem;
    color: #ffff00;
  }

  .prose h2 {
    font-size: 2rem;
    color: #ffff00;
  }
  .dark .prose h1 {
    font-size: 2rem;
    color: #ffff00;
  }

  .dark .prose h2 {
    font-size: 2rem;
    color: #ffff00;
  }
  .prose h3 {
    font-size: 1.25rem;
    color: #ffffff;
  }

  .prose p {
    margin-bottom: 1rem;
    color: #ffffff;
  }

  .prose a {
    color: #007bff;
    text-decoration: none;
  }

  .dark .prose a {
    color: #60a5fa;
  }

  .prose a:hover {
    text-decoration: underline;
  }

  .prose pre {
    background-color: #2d2d2d;
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .dark .prose pre {
    background-color: #1f2937;
  }

  .prose code {
    background-color: #f4f4f4;
    color: #1f2937;
    padding: 0.2rem 0.4rem;
    border-radius: 0.25rem;
    font-size: 0.9em;
  }

  .dark .prose code {
    background-color: #374151;
    color: #e5e7eb;
  }

  .prose pre code {
    background-color: transparent;
    padding: 0;
    color: #f8f8f2;
  }

  .prose ul,
  .prose ol {
    margin-bottom: 1.5rem;
    padding-left: 2rem;
  }

  .prose li {
    margin-bottom: 0.5rem;
  }

  .prose blockquote {
    border-left: 4px solid #ddd;
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: #666;
    font-style: italic;
  }

  .dark .prose blockquote {
    border-left-color: #4b5563;
    color: #9ca3af;
  }

  .prose img {
    max-width: 100%;
    height: auto;
    margin: 1.5rem;
  }
  .table {
    align-self: center;
  }
  .prose table {
    @apply mx-auto;
    width: 90%;
    border-collapse: collapse;
  }

  .prose th,
  .prose td {
    border: 1px solid #ddd;
    padding: 0.75rem;
    text-align: center;
  }

  .dark .prose th,
  .dark .prose td {
    border-color: #4b5563;
  }

  .prose th {
    background-color: #f4f4f4;
    font-weight: 600;
  }

  .dark .prose th {
    background-color: #374151;
  }

  @font-face {
    font-family: "Oblata Display";
    /* 1. Point to the .otf file extension */
    src: url("/fonts/OblataDisplayRegular.otf") format("opentype"); /* 2. Change format to 'opentype' */
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }
</style>
