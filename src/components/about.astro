---
import { SITE_CONFIG } from "../config";
---

<div class="mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <h2
    class="text-3xl font-bold text-center uppercase text-gray-600 dark:text-gray-400 mb-6"
  >
    About me
  </h2>

  <!-- Icon Divider -->
  <div class="divider-custom">
    <div class="divider-custom-line"></div>
  </div>

  <div class="flex flex-col items-center text-gray-600 dark:text-gray-400 mt-8">
    <h1 class="text-2xl font-semibold mb-8 text-gray-900 dark:text-gray-100">
      Stacey Charnock
    </h1>
    <div
      class="w-full space-y-6 text-gray-700 dark:text-gray-300 leading-relaxed"
    >
      <p>
        Nourishing the St Francis Community Saucy Stuff was born out of a love
        for wholesome cooking and a desire to make healthy eating effortless for
        our community in St Francis Bay.
      </p>
      <p>
        Our unique concept focuses on a daily rotating pre-order menu. By
        mastering one signature meal per day, with optional sides. We guarantee
        the highest quality, maximum freshness, with No MSG,additives,
        colourants or preservatives. From nourishing salads to vibrant Thai
        curries, our generous portions are prepared without compromises—using
        organic herbs and spices, cold pressed olive and coconut oils, and
        maintaining a predominantly gluten-free menu.
      </p>
      <p>
        Let us handle the cooking tonight. Browse our weekly menu, customize
        your sides, and let us deliver a wholesome feast to your home.
      </p>

      <div class="mt-8">
        <h3
          class="text-2xl font-semibold mb-4 text-gray-900 dark:text-gray-100"
        >
          Get In Touch
        </h3>
        <p>Feel free to connect with me on:</p>
        <ul class="list-disc list-inside mt-2">
          {
            SITE_CONFIG.socialLinks.github && (
              <li>
                GitHub:{" "}
                <a
                  href={`https://github.com/${SITE_CONFIG.socialLinks.github}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-blue-600 dark:text-blue-400 hover:underline"
                >
                  @{SITE_CONFIG.socialLinks.github}
                </a>
              </li>
            )
          }
          {
            SITE_CONFIG.socialLinks.whatsapp && (
              <li>
                WhatsApp:{""}
                <a
                  href={`https://wa.me/${SITE_CONFIG.socialLinks.whatsapp}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-blue-600 dark:text-blue-400 hover:underline"
                >
                  {SITE_CONFIG.socialLinks.whatsapp}
                </a>
              </li>
            )
          }
          {
            SITE_CONFIG.email && (
              <li>
                Email:{" "}
                <a
                  href={`mailto:${SITE_CONFIG.email}`}
                  class="text-blue-600 dark:text-blue-400 hover:underline"
                >
                  {SITE_CONFIG.email}
                </a>
              </li>
            )
          }
        </ul>
      </div>
    </div>
  </div>
</div>
