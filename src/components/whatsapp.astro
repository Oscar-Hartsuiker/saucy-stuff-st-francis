---
// src/components/WhatsAppContactForm.astro
const whatsappNumber = "27813885967"; // your number, country code + digits, no + or spaces
---

<form
  id="wa-contact-form"
  class="w-full mx-auto border-gray-500 border p-6 rounded-2xl space-y-4"
>
  <div class="form-control">
    <label class="label" for="wa-name">
      <span class="label-text text-center m-2">Name</span>
    </label>
    <input
      id="wa-name"
      name="name"
      type="text"
      placeholder="Your name"
      class="input border p-2 border-gray-500 rounded-2xl w-full"
      required
    />
  </div>

  <div class="form-control">
    <label class="label" for="wa-message">
      <span class="label-text text-center m-2">Message</span>
    </label>
    <textarea
      id="wa-message"
      name="message"
      class="textarea border-gray-500 border rounded-2xl p-2 w-full"
      rows="4"
      placeholder="What can we do for you?"
      required></textarea>
  </div>

  <button
    type="submit"
    class="btn btn-primary w-full px-6 py-3 border border-gray-500 bg-green-400 hover:bg-green-300 dark:bg-green-400 dark:hover:bg-green-300 text-gray-900
            font-medium rounded-lg transition-colors duration-200"
  >
    Send via WhatsApp
  </button>
</form>

<script define:vars={{ whatsappNumber }}>
  const form = document.getElementById("wa-contact-form");

  form?.addEventListener("submit", (e) => {
    e.preventDefault();

    const name = form.querySelector("#wa-name").value.trim();
    const message = form.querySelector("#wa-message").value.trim();

    const text = `Hi, my name is ${name}.\n\n${message}`;
    const encodedText = encodeURIComponent(text);

    const url = `https://wa.me/${whatsappNumber}?text=${encodedText}`;
    window.open(url, "_blank");
  });
</script>
